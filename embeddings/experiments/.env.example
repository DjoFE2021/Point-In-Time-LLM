# Path to the JKP 132-factor panel pickle (indexed by date, id)
JKP_PANEL_PATH=/srv/data/lfm/usa_132_per_size_ranks_False_permno_False_float32.pkl

# Path to the raw (equal-weighted) Mistral embeddings pickle
MISTRAL_RAW_PATH=/srv/datasets/mistral_djnw/mistral-7b-instruct_ew.pkl

# Path to the pre-residualized Mistral/DJN 132-factor features pickle
MISTRAL_RESIDUAL_PATH=/srv/datasets/mistral_djnw_132_residuals_mega_large/DJN_132_features.pkl

# Base directory for per-model embedding folders (subfolder name = model_name arg)
EMBEDDINGS_DIR=/srv/datasets/embeddings

# Directory where experiment outputs (plots, result arrays) are written
OUTPUT_PATH=/srv/results/pit_llm
